# Copie pra .env e preencha com os dados do seu projeto Supabase.
# Sem essas variáveis, o app roda em MODO DEMONSTRAÇÃO (sem backend, sem gastar análise).

VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key

# Secrets do Supabase (NÃO vão no .env do frontend — configure com:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
#   supabase secrets set ADMIN_SENHA=uma-senha-forte
#   supabase secrets set APIFY_TOKEN=apify_api_...   # só pra análise pelo link do perfil
# )
